# ============================================================
# SAU EconHub — Environment Variables Template
# Copy this file to .env.local and fill in your own values.
# NEVER commit .env.local to version control.
# ============================================================

# ── Supabase ─────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ── Cloudinary ───────────────────────────────────────────────
# Found in: Cloudinary Dashboard → Settings → API Keys
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=your_upload_preset_name

# ── Groq ─────────────────────────────────────────────────────
# Generate at: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key
